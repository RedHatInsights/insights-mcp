{
  "templates": {
    "inventory_host_read": {
      "application": "inventory",
      "required_v1_permissions": [["inventory:hosts:read"]],
      "kessel_permission": "inventory_host_view",
      "kessel_note": "",
      "recommended_roles": ["Inventory Hosts Viewer"],
      "openapi_sources": [
        "https://github.com/RedHatInsights/insights-host-inventory/blob/master/swagger/api.spec.yaml"
      ]
    },
    "vuln_results_read": {
      "application": "vulnerability",
      "required_v1_permissions": [
        ["vulnerability:vulnerability_results:read", "inventory:hosts:read"]
      ],
      "kessel_permission": "vulnerability_vulnerability_results_view",
      "kessel_note": "Kessel: vulnerability_vulnerability_results_view requires inventory_host_view on the host workspace (see RedHatInsights/rbac-config vulnerability.ksl).",
      "recommended_roles": ["Vulnerability viewer", "Inventory Hosts Viewer"],
      "openapi_sources": ["apis/vulnerability-openapi.json"]
    }
  },
  "tools": {
    "inventory__list_hosts": {
      "method": "GET",
      "api_path": "api/inventory/v1",
      "path_template": "/hosts",
      "template": "inventory_host_read",
      "verified": true,
      "upstream": {
        "repo": "RedHatInsights/insights-host-inventory",
        "file": "api/host.py",
        "handler": "get_host_list",
        "rbac_decorators": ["KesselResourceTypes.HOST.view"]
      }
    },
    "inventory__get_host_details": {
      "method": "GET",
      "api_path": "api/inventory/v1",
      "path_template": "/hosts/{host_ids}",
      "template": "inventory_host_read"
    },
    "inventory__get_host_system_profile": {
      "method": "GET",
      "api_path": "api/inventory/v1",
      "path_template": "/hosts/{host_ids}/system_profile",
      "template": "inventory_host_read"
    },
    "inventory__get_host_tags": {
      "method": "GET",
      "api_path": "api/inventory/v1",
      "path_template": "/hosts/{host_ids}/tags",
      "template": "inventory_host_read"
    },
    "inventory__find_host_by_name": {
      "method": "GET",
      "api_path": "api/inventory/v1",
      "path_template": "/hosts",
